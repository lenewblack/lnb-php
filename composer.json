{
    "name": "lenewblack/lnb-php",
    "description": "PHP SDK for Le New Black Wholesale v2 API",
    "type": "library",
    "version": "1.0.0",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "LeNewBlack\\Wholesale\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LeNewBlack\\Wholesale\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
